#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/home/ubuntu/sonagi-draw-repo/node_modules/.pnpm/@apm-js-collab+code-transformer@0.18.0/node_modules/@apm-js-collab/code-transformer/node_modules:/home/ubuntu/sonagi-draw-repo/node_modules/.pnpm/@apm-js-collab+code-transformer@0.18.0/node_modules:/home/ubuntu/sonagi-draw-repo/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/home/ubuntu/sonagi-draw-repo/node_modules/.pnpm/@apm-js-collab+code-transformer@0.18.0/node_modules/@apm-js-collab/code-transformer/node_modules:/home/ubuntu/sonagi-draw-repo/node_modules/.pnpm/@apm-js-collab+code-transformer@0.18.0/node_modules:/home/ubuntu/sonagi-draw-repo/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../@apm-js-collab/code-transformer/cli.js" "$@"
else
  exec node  "$basedir/../@apm-js-collab/code-transformer/cli.js" "$@"
fi
